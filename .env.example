# PostgreSQL database connection URL for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maison_tunis?schema=public"

# NextAuth configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-at-least-32-characters"

# JWT Fallback Secret (used for custom session token fallback)
JWT_SECRET="your-fallback-jwt-secret-key-at-least-32-characters"

# Public API URL (defaults to relative /api for same-origin client requests)
NEXT_PUBLIC_API_URL="/api"
