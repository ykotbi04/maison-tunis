{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "mcp_timeout": 300000
  },
  "mcp": {
    "stitch": {
      "type": "local",
      "command": ["npx", "-y", "@_davideast/stitch-mcp@latest", "proxy"],
      "enabled": true,
      "timeout": 300000,
      "environment": {
        "STITCH_API_KEY": "{env:STITCH_API_KEY}",
        "STITCH_USE_SYSTEM_GCLOUD": "1",
        "GOOGLE_CLOUD_PROJECT": "maison-tunis-stitch",
        "CI": "1",
        "DOTENV_CONFIG_QUIET": "true",
        "DOTENV_QUIET": "true",
        "NO_COLOR": "1"
      }
    }
  }
}
